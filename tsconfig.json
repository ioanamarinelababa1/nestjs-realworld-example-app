{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "module": "commonjs",
    "target": "es6",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "allowJs": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}