{
  "compilerOptions": {
    "rootDir": "./src",
    "strict": false,                 // Dezactivează regulile foarte dure
    "strictNullChecks": false,       // Rezolvă erorile cu 'null' și 'undefined'
    "noImplicitAny": false,
    "module": "commonjs",
    "declaration": false,
    "noImplicitAny": false,
    "removeComments": true,
    "noLib": false,
    "lib": ["es2017"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es6",
    "sourceMap": true,
    "allowJs": true,
    "outDir": "./dist"
  },
    "include": [
    "src/**/*"
  ],
    "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ]
}
